# =============================================================================
# Frontend environment variables
# Copy this file to .env.local (dev) or .env.production (prod).
# NEVER commit the actual .env.local / .env.production files to git.
# =============================================================================

# ── Backend API URL ────────────────────────────────────────────────────────────
# IMPORTANT: NEXT_PUBLIC_* variables are baked into the JavaScript bundle at
# BUILD TIME by Next.js. Setting this at container runtime has NO effect.
#
# For production Docker builds, this must be passed as a build arg:
#   docker build --build-arg NEXT_PUBLIC_API_URL=https://yourdomain.com/api .
#
# If Nginx proxies /api/ → backend:4000 (recommended):
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# Direct backend URL (if NOT going through Nginx /api/ prefix):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Copy this file to .env for local development
# Copy to .env.production for production

# OpenAI / LangChain
OPENAI_API_KEY=sk-...

# Optional: local Ollama endpoint
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# Optional: Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Local PostgreSQL connection (if the processing service reads/writes the DB directly)
DATABASE_URL="postgresql://postgres:Admin123@host.docker.internal:5432/mydb?sslmode=disable"

# =============================================================================
# Processing service environment variables
# Copy this file to .env (dev) or .env.production (prod) and fill in values.
# NEVER commit the actual .env / .env.production files to git.
# =============================================================================

# ── Backend API ────────────────────────────────────────────────────────────────
# Internal Docker network name — do NOT use localhost here
NODE_API_URL=http://backend:4000

# ── Job store data directory ───────────────────────────────────────────────────
# Path where SQLite job DB and uploaded PDF bytes are stored.
# Must match the Docker volume mount path in docker-compose.prod.yml (/app/data).
DATA_DIR=/app/data

# ── OpenAI (optional) ──────────────────────────────────────────────────────────
# Required only if AI-assisted comparison or generation features are enabled
# OPENAI_API_KEY=sk-...

# ── AWS S3 (optional) ──────────────────────────────────────────────────────────
# Required only if external file storage is configured (not used by default)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=structo-uploads

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserRole {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  features  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Team {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  taskAssignments TaskAssignment[]
  members         User[]
}

model User {
  id                Int               @id @default(autoincrement())
  password          String
  firstName         String?
  lastName          String?
  role              Role              @default(USER)
  status            Status            @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdById       Int?
  userId            String            @unique
  teamId            Int?
  userRoleId        Int?
  passwordChangedAt DateTime          @default(now())
  uploads           FileUpload[]
  passwordHistories PasswordHistory[]
  taskAssignees     TaskAssignee[]
  createdTasks      TaskAssignment[]  @relation("CreatedByUser")
  createdBy         User?             @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers      User[]            @relation("UserCreatedBy")
  team              Team?             @relation(fields: [teamId], references: [id])
  userRole          UserRole?         @relation(fields: [userRoleId], references: [id])
  userLogs          UserLog[]
  validations       Validation[]
  createdBrds       Brd[]             @relation("BrdCreatedBy")
}

model TaskAssignment {
  id          Int              @id @default(autoincrement())
  title       String
  description String?
  status      AssignmentStatus @default(PENDING)
  percentage  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  dueDate     DateTime?
  teamId      Int
  createdById Int
  brdFileId   Int?
  assignees   TaskAssignee[]
  brdFile     FileUpload?      @relation(fields: [brdFileId], references: [id])
  createdBy   User             @relation("CreatedByUser", fields: [createdById], references: [id])
  team        Team             @relation(fields: [teamId], references: [id])
}

model TaskAssignee {
  id           Int            @id @default(autoincrement())
  assignmentId Int
  userId       Int
  assignedAt   DateTime       @default(now())
  assignment   TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
}

model UserLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model FileUpload {
  id           Int              @id @default(autoincrement())
  originalName String
  fileType     String
  fileSize     Int
  storagePath  String
  status       TaskStatus       @default(PENDING)
  uploadedAt   DateTime         @default(now())
  processedAt  DateTime?
  submittedAt  DateTime?
  uploadedById Int
  output       FileOutput?
  uploadedBy   User             @relation(fields: [uploadedById], references: [id])
  tasks        TaskAssignment[]
  validation   Validation?
  brd          Brd?             @relation("BrdSourceFile")
}

model FileOutput {
  id          Int        @id @default(autoincrement())
  filename    String
  storagePath String
  fileSize    Int
  createdAt   DateTime   @default(now())
  uploadId    Int        @unique
  upload      FileUpload @relation(fields: [uploadId], references: [id])
}

model Validation {
  id            Int        @id @default(autoincrement())
  status        String
  remarks       String?
  validatedAt   DateTime   @default(now())
  uploadId      Int        @unique
  validatedById Int
  upload        FileUpload @relation(fields: [uploadId], references: [id])
  validatedBy   User       @relation(fields: [validatedById], references: [id])
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  hash      String
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER_QA
  MANAGER_QC
  USER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  PENDING
  PROCESSING
  PROCESSED
  SUBMITTED
  APPROVED
  REJECTED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ── BRD ───────────────────────────────────────────────────────────────────────

enum BrdFormat {
  NEW
  OLD
}

enum BrdStatus {
  DRAFT
  PAUSED
  COMPLETED
  APPROVED
  ON_HOLD
}

model Brd {
  id          Int       @id @default(autoincrement())
  brdId       String    @unique
  title       String
  format      BrdFormat @default(NEW)
  status      BrdStatus @default(DRAFT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById Int
  uploadId    Int?      @unique

  upload    FileUpload?  @relation("BrdSourceFile", fields: [uploadId], references: [id])
  createdBy User         @relation("BrdCreatedBy", fields: [createdById], references: [id])
  sections  BrdSections?
}

// One row per BRD. All section data stored as JSON blobs.
model BrdSections {
  id    Int    @id @default(autoincrement())
  brdId String @unique
  brd   Brd    @relation(fields: [brdId], references: [brdId], onDelete: Cascade)

  scope          Json?   // { in_scope: [], out_of_scope: [] }
  metadata       Json?   // flat key-value object (new or old format)
  toc            Json?   // { sections: [] }
  citations      Json?   // { references: [] }
  contentProfile Json?   // { rc_filename, heading_annotation, levels: [], whitespace: [] }
  brdConfig      Json?   // catch-all for extractor extras
  innodMetajson Json?   // original innod metadata JSON blob (for debugging)
  simpleMetajson Json?   // simplified metadata JSON blob (for easier frontend use)

  cellImages BrdCellImage[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brd_sections")
}
model BrdCellImage {
  id          Int         @id @default(autoincrement())
  brdId       String
  brdSections BrdSections @relation(fields: [brdId], references: [brdId], onDelete: Cascade)

  tableIndex  Int
  rowIndex    Int
  colIndex    Int
  rid         String
  mediaName   String
  mimeType    String
  cellText    String      @default("")

  // ── NEW: semantic location fields (populated by updated image_extractor.py)
  section     String      @default("unknown") 
  fieldLabel  String      @default("")        

  imageData   Bytes?     
  blobUrl     String?     
  extractedAt DateTime    @default(now())

  @@unique([brdId, tableIndex, rowIndex, colIndex, rid])
  @@index([brdId])
  @@index([brdId, section])   
  @@map("brd_cell_images")
}
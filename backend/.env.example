# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/mydb?sslmode=disable

# Secret used to sign JWT tokens – generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-strong-random-secret

# Allowed CORS origin (your frontend URL)
FRONTEND_URL=http://localhost:3000

# Express port (optional, defaults to 4000)
PORT=4000

# URL of the Python processing service (internal)
PROCESSING_SERVICE_URL=http://localhost:8000

# Resend email service (https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Super-admin user ID (optional – grants elevated privileges)
SUPERADMIN_USERID=

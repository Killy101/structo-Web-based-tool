# Copy this file to .env for local development
# Copy to .env.production for production

PORT=4000
NODE_ENV=development

# Prisma / PostgreSQL — use the pooled connection string from Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true

# Direct (non-pooled) connection required for Prisma migrations
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase project credentials
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Auth
JWT_SECRET=your-very-long-random-jwt-secret

# CORS — origin of the Next.js frontend
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: override processing service URL if called server-side
PROCESSING_URL=http://processing:8000

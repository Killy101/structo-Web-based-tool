# =============================================================================
# Backend environment variables
# Copy this file to .env (dev) or .env.production (prod) and fill in values.
# NEVER commit the actual .env / .env.production files to git.
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Self-hosted (Docker Compose db service):
DATABASE_URL=postgresql://structo:your-db-password@db:5432/structo

# AWS RDS — uncomment and replace if using managed database instead:
# DATABASE_URL=postgresql://structo:your-db-password@your-cluster.rds.amazonaws.com:5432/structo

# ── Security ───────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace-with-64-char-random-hex-string

# ── Service URLs ───────────────────────────────────────────────────────────────
# Internal Docker network names — do NOT use localhost here
PROCESSING_URL=http://processing:8000
FRONTEND_URL=https://yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── App ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Superadmin seed ────────────────────────────────────────────────────────────
# User ID for the first superadmin account created on first boot
SUPERADMIN_USERID=SADMIN

# ── PostgreSQL credentials (used by docker-compose db service) ─────────────────
# These must match what you set in DATABASE_URL above
POSTGRES_USER=structo
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=structo
